<a
  class="nsw-quick-exit"
  href="{{#if safeUrl}}{{safeUrl}}{{else}}https://www.google.com/webhp{{/if}}"
  data-options='{
    "enableEsc": {{#if-equals enableEsc false}}false{{else}}true{{/if-equals}},
    "enableCloak": {{#if-equals enableCloak false}}false{{else}}true{{/if-equals}},
    "enableHistoryMask": {{#if-equals enableHistoryMask false}}false{{else}}true{{/if-equals}},
    "historyMaskUrl": "{{#if historyMaskUrl}}{{historyMaskUrl}}{{else}}/{{/if}}",
    "historyMaskTitle": "{{#if historyMaskTitle}}{{historyMaskTitle}}{{else}}NSW Government{{/if}}"
  }'
  rel="nofollow noopener"
  id="nsw-quick-exit"
  aria-label="Quick exit"
  aria-describedby="nsw-quick-exit__desc"
>
  <div class="nsw-quick-exit__content">
    <span
      id="nsw-quick-exit__desc"
      class="nsw-quick-exit__description-text"
    >
      {{#if qe-description}}{{{qe-description}}}{{else}}Leave quickly using this banner or press <kbd aria-label="Escape key">Esc</kbd> 2 times.{{/if}}
    </span>
    <span class="nsw-quick-exit__exit-text">Exit now</span>
  </div>
</a>