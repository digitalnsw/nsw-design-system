---
title: Quick exit
page: true
model:  json/quick-exit.json
---

{{#>_theme}}
{{#>_layout-container}}
<h3>Quick exit feature</h3>
<ul class="nsw-m-bottom-md">
<li>Cloaks page immediately on activation</li>
<li>Replaces the current history entry with the same-origin home page and neutral page title before navigating to the Safe URL</li>
</ul>

<button class="nsw-button nsw-button--dark" data-module="quick-exit" type="button">View banner</button>

<script>
  (function () {
    if (typeof document === 'undefined') return;
    document.addEventListener('DOMContentLoaded', function () {
      var btn = document.querySelector('[data-module="quick-exit"]');
      if (!btn || !window.NSW || !window.NSW.QuickExit) return;

      btn.addEventListener('click', function () {
        window.NSW.QuickExit.init({
          safeUrl: "{{model.safeUrl}}",
          description: "{{{model.qe-description}}}",
          enableEsc: true,
          enableCloak: true,
          enableHistoryMask: true,
          historyMaskUrl: "{{model.historyMaskUrl}}",
          historyMaskTitle: "{{model.historyMaskTitle}}"
        });

      });
    });
  }());
</script>
{{/_layout-container}}
{{/_theme}}
