---
title: Easy Read content block
width: wide
page: true
model:
  easy-read-1: ../../components/easy-read/json/easy-read-1.json
  easy-read-2: ../../components/easy-read/json/easy-read-2.json
  easy-read-3: ../../components/easy-read/json/easy-read-3.json
  easy-read-4: ../../components/easy-read/json/easy-read-4.json
---

{{#>_theme}}
{{#>_layout-container}}
<div class="nsw-easy-read-content">
  <h2>Default section</h2>
  {{>_easy-read-block model.easy-read-1}}
  {{>_easy-read-block model.easy-read-2}}
</div>
{{/_layout-container}}

{{#>_layout-container brand-dark="true"}}
<div class="nsw-easy-read-content">
  <h2>Brand dark section</h2>
  {{>_easy-read-block model.easy-read-3}}
  {{>_easy-read-block model.easy-read-2}}
</div>
{{/_layout-container}}

{{#>_layout-container brand-light="true"}}
<div class="nsw-easy-read-content">
  <h2>Brand light section</h2>
  {{>_easy-read-about}}
  {{>_easy-read-block model.easy-read-4}}
</div>
{{/_layout-container}}

{{#>_layout-container brand-dark="true" invert="true"}}
<div class="nsw-easy-read-content">
  <h2>Inverted section</h2>
  {{>_easy-read-block model.easy-read-1}}
  {{>_easy-read-block model.easy-read-2}}
</div>
{{/_layout-container}}
{{/_theme}}
