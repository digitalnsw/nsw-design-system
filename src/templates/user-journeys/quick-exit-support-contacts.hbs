{{>_main-nav model.nav}}
<script>
  (function () {
    var nav = document.getElementById('main-nav')
    if (!nav) return
    nav.querySelectorAll('a[href]').forEach(function (link) {
      link.addEventListener('click', function (event) {
        event.preventDefault()
      })
    })
  })()
</script>

