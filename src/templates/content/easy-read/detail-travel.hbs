---
title: Easy Read detail article (accessible travel)
meta-description: Example Easy Read article explaining how to plan accessible public transport with purpose-made illustrations.
meta-index: true
order: 25
page: true
directory: Easy Read
model:
  nav-basic: ../../../components/main-nav/json/main-nav.json
  page: ../../../docs/content/methods/json/easy-read-detail-travel.json
  share: ../../../docs/content/methods/json/easy-read-share.json
  footer: ../../../components/footer/json/footer.json
---

{{>_masthead content="#content" nav="#main-nav"}}
{{>_header header-title="NSW Department"}}
{{>_main-nav model.nav-basic}}
<div class="nsw-container nsw-p-bottom-xs">
  {{>_breadcrumbs model.page.breadcrumbs}}
</div>

<div class="nsw-container nsw-easy-read-content nsw-p-top-sm nsw-p-bottom-lg">
  <div class="nsw-layout">
    <main id="content" class="nsw-layout__main">
      <div class="nsw-block">
        <h1>
          <span class="nsw-tag">Easy Read</span>
          <span class="nsw-easy-read-content__heading-text">{{model.page.title}}</span>
        </h1>
        <p class="nsw-intro">{{model.page.introduction}}</p>
      </div>

      {{>_easy-read-read-aloud}}

      <nav class="nsw-in-page-nav" aria-label="On this page">
        <h2 class="nsw-in-page-nav__title">On this page</h2>
        <ul class="nsw-in-page-nav__list">
          {{#each model.page.blocks}}
          <li><a href="#{{id}}">{{title}}</a></li>
          {{/each}}
        </ul>
      </nav>

      <div class="nsw-block">
        {{#each model.page.openingParagraphs}}
        <p>{{this}}</p>
        {{/each}}
      </div>

      {{#each model.page.blocks}}
      <div class="nsw-block" id="{{id}}">
        {{>_easy-read-block this}}
      </div>
      {{/each}}

      {{>_easy-read-downloads-utility model.page.downloads social=model.share}}

      {{>_easy-read-metadata model.page filesUpdated=model.page.downloads}}

      <hr class="nsw-m-y-lg">

      <div class="nsw-block nsw-p-bottom-md">
        {{>_easy-read-about model.page.about}}
      </div>
    </main>
  </div>
</div>

{{>_footer model.footer}}
