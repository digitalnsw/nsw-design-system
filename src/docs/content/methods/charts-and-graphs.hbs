---
title: Charts and graphs
no-blank: true
intro: Charts and graphs help users understand data quickly.
order: 15
model:
  principles: json/charts-and-graphs-principles.json
  page: json/charts-and-graphs-page.json
  chartTypes: json/charts-and-graphs-chart-types.json
  sections: json/charts-and-graphs-content-sections.json
  brand: json/charts-and-graphs-brand-guidance.json
  pitfalls: json/charts-and-graphs-pitfalls.json
  review: json/charts-and-graphs-review.json
meta-description: NSW Design System guidance for charts and graphs in digital products, aligned to NSW Brand Toolkit principles and accessibility requirements.
meta-index: true
---

<nav class="nsw-in-page-nav" aria-labelledby="in-page-nav">
  <div id="in-page-nav" class="nsw-in-page-nav__title">On this page</div>
  <ul>
    {{#each model.page.inPageNav}}
    <li>
      <a href="{{href}}">{{label}}</a>
    </li>
    {{/each}}
  </ul>
</nav>


<h2 id="about-this-guidance">{{model.page.about.heading}}</h2>
{{#each model.page.about.paragraphs}}
<p>{{this}}</p>
{{/each}}

<h3>{{model.page.about.outOfScopeHeading}}</h3>
<ul>
  {{#each model.page.about.outOfScopeItems}}
  <li>{{this}}</li>
  {{/each}}
</ul>
<p>{{model.page.about.outOfScopeConclusion}}</p>

<h2 id="principles">Principles</h2>
<p>These principles apply to all charts and graphs in NSW digital products.</p>
<div class="nsw-grid nsw-grid--spaced nsw-m-top-sm">
  {{#each model.principles.principlesIconBlocks}}
  <div class="nsw-col nsw-col-md-6 nsw-col-lg-4">
    {{>_content-block this}}
  </div>
  {{/each}}
</div>


<h2 id="choose-the-right-chart-type">{{model.page.chooseChartType.heading}}</h2>
{{#each model.page.chooseChartType.introHtml}}
<p>{{{this}}}</p>
{{/each}}

<div class="nsw-grid nsw-m-top-sm">
  <div class="nsw-col nsw-col-sm-6 nsw-docs__guideline">
    <div class="nsw-docs__guideline--do"><span class="material-icons nsw-material-icons" focusable="false" aria-hidden="true">check_circle</span><span>{{model.page.chooseChartType.guidelines.doTitle}}</span></div>
    <ul>
      {{#each model.page.chooseChartType.guidelines.doItems}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
  </div>
  <div class="nsw-col nsw-col-sm-6 nsw-docs__guideline">
    <div class="nsw-docs__guideline--dont"><span class="material-icons nsw-material-icons" focusable="false" aria-hidden="true">cancel</span><span>{{model.page.chooseChartType.guidelines.dontTitle}}</span></div>
    <ul>
      {{#each model.page.chooseChartType.guidelines.dontItems}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
  </div>
</div>

{{#each model.chartTypes.sections}}
<h3>{{title}}</h3>
<div class="nsw-grid nsw-docs__chart-option-grid">
  {{#each charts}}
  <div class="nsw-col nsw-col-12 nsw-col-lg-6 nsw-docs__chart-option">
    <h4 id="{{id}}" class="nsw-m-bottom-sm">{{title}}</h4>
    <div class="nsw-grid nsw-docs__chart-example">
      <div class="nsw-col nsw-col-12">
        <canvas id="{{canvasId}}" data-chart-height="{{canvasHeight}}" role="img" aria-label="{{ariaLabel}}"></canvas>
      </div>
      <div class="nsw-col nsw-col-12 nsw-docs__chart-example-details">
        <div class="nsw-docs__list-stack">
          <p><strong>Use when:</strong> {{details.useWhen}}</p>
          <p><strong>Avoid when:</strong> {{details.avoidWhen}}</p>
          <p><strong>Notes:</strong> {{details.notes}}</p>
        </div>
      </div>
    </div>
  </div>
  {{/each}}
</div>
{{/each}}


<h2 id="never-mislead-with-data">{{model.sections.section2.heading}}</h2>
<p>{{model.sections.section2.intro}}</p>
<ul>
  {{#each model.sections.section2.bullets}}
  <li>{{this}}</li>
  {{/each}}
</ul>

<h3 id="chart-anatomy">{{model.sections.section2.anatomy.heading}}</h3>
<p>{{model.sections.section2.anatomy.intro}}</p>

<div class="nsw-grid nsw-m-top-sm">
  <div class="nsw-col nsw-col-lg-12">
    <div class="nsw-docs__chart-anatomy">
      <p class="nsw-docs__chart-anatomy-note sr-only">{{model.sections.section2.anatomy.srNote}}</p>
      <div class="nsw-docs__chart-anatomy-stage">
        <div class="nsw-docs__chart-anatomy-canvas">
          <canvas id="chartAnatomy" role="img" aria-label="{{model.sections.section2.anatomy.canvasAriaLabel}}"></canvas>
        </div>
        <p class="nsw-docs__chart-anatomy-meta">
          <strong>{{model.sections.section2.anatomy.meta.sourceLabel}}</strong> {{model.sections.section2.anatomy.meta.sourceValue}}
          <span class="nsw-docs__chart-anatomy-meta-divider" aria-hidden="true">|</span>
          <strong>{{model.sections.section2.anatomy.meta.updatedLabel}}</strong> {{model.sections.section2.anatomy.meta.updatedValue}}
        </p>
        {{#each model.sections.section2.anatomy.pins}}
        <span class="nsw-docs__chart-anatomy-pin nsw-docs__chart-anatomy-pin--{{modifier}}" aria-hidden="true">{{number}}</span>
        {{/each}}
      </div>
    </div>
  </div>
  <div class="nsw-col nsw-col-lg-12">
    <ol class="nsw-list nsw-list--8 nsw-docs__chart-anatomy-list">
      {{#each model.sections.section2.anatomy.items}}
      <li><strong>{{label}}</strong> {{text}}</li>
      {{/each}}
    </ol>
  </div>
</div>

<h2 id="make-the-message-obvious">{{model.sections.section3.heading}}</h2>
<p>{{model.sections.section3.intro}}</p>
<ul>
  {{#each model.sections.section3.bullets}}
  <li>{{this}}</li>
  {{/each}}
</ul>

<h3>{{model.sections.section3.dashboardHeading}}</h3>
<ul>
  {{#each model.sections.section3.dashboardBullets}}
  <li>{{this}}</li>
  {{/each}}
</ul>

<h2 id="meet-accessibility-standards">{{model.sections.section4.heading}}</h2>
<p>{{model.sections.section4.intro}}</p>
{{#each model.sections.section4.subsections}}
<h3>{{heading}}</h3>
{{#if intro}}
<p>{{intro}}</p>
{{/if}}
<ul>
  {{#each bullets}}
  <li>{{this}}</li>
  {{/each}}
</ul>
{{/each}}


<h2 id="apply-nsw-brand-consistently">{{model.brand.heading}}</h2>
<p>{{model.brand.intro}}</p>

<h3>{{model.brand.selectionMethod.heading}}</h3>
<p>{{{model.brand.selectionMethod.contrastRule}}}</p>
<p>{{model.brand.selectionMethod.intro}}</p>
<p>{{model.brand.selectionMethod.beforeImageText}}</p>
<div class="nsw-m-top-sm nsw-m-bottom-md">
  <img class="nsw-display-block nsw-width-100 nsw-width-md-75" src="{{model.brand.selectionMethod.images.[0].src}}" alt="{{model.brand.selectionMethod.images.[0].alt}}" loading="lazy">
</div>
<div class="nsw-in-page-alert nsw-width-100 nsw-width-md-75 nsw-in-page-alert--warning nsw-in-page-alert--compact nsw-m-bottom-md">
  <span class="material-icons nsw-material-icons nsw-in-page-alert__icon" focusable="false" aria-hidden="true">error</span>
  <div class="nsw-in-page-alert__content">
    <p class="nsw-small">{{{model.brand.selectionMethod.warning}}}</p>
  </div>
</div>
<p>{{model.brand.selectionMethod.afterImageText}}</p>
<div class="nsw-m-top-sm nsw-m-bottom-md">
  <img class="nsw-display-block nsw-width-100 nsw-width-md-75" src="{{model.brand.selectionMethod.images.[1].src}}" alt="{{model.brand.selectionMethod.images.[1].alt}}" loading="lazy">
</div>
<p>{{model.brand.selectionMethod.consistencyText}}</p>

<h4>{{model.brand.background.heading}}</h4>
<p>{{{model.brand.background.text}}}</p>

<h4>{{model.brand.nswPalette.heading}}</h4>
<div class="nsw-section nsw-section--white nsw-block nsw-p-x-sm nsw-p-top-sm">
  <div class="nsw-table nsw-table--valign-middle nsw-docs__table-wrap">
    <table class="nsw-docs__chart-colour-table">
      <caption class="sr-only">{{model.brand.nswPalette.caption}}</caption>
      <colgroup>
        <col class="nsw-docs__chart-colour-col-swatch">
        <col class="nsw-docs__chart-colour-col-colour-value">
        <col class="nsw-docs__chart-colour-col-contrast">
        <col class="nsw-docs__chart-colour-col-swatch">
        <col class="nsw-docs__chart-colour-col-line-value">
        <col class="nsw-docs__chart-colour-col-pattern-contrast">
      </colgroup>
      <thead>
        <tr>
          {{#each model.brand.nswPalette.headers}}
          <th>{{this}}</th>
          {{/each}}
        </tr>
      </thead>
      <tbody>
        {{#each model.brand.nswPalette.rows}}
        <tr>
          <td>
            <svg class="nsw-docs__pattern-table-swatch" viewBox="0 0 40 40" aria-hidden="true" focusable="false">
              <circle cx="20" cy="20" r="18" fill="var({{fillVar}})"></circle>
            </svg>
            <span class="sr-only">{{name}} plain swatch</span>
          </td>
          <td>{{name}} (<code>{{hex}}</code>)</td>
          <td><code>{{contrast}}</code></td>
          <td>
            <svg class="nsw-docs__pattern-table-swatch" viewBox="0 0 40 40" aria-hidden="true" focusable="false">
              <defs>
                <pattern id="nsw-pattern-select-{{key}}" patternUnits="userSpaceOnUse" width="8" height="8">
                  <path d="M-1,1 l4,-4 M0,8 l8,-8 M6,10 l4,-4" stroke="var({{lineVar}})" stroke-width="1.5" fill="none" shape-rendering="crispEdges"></path>
                </pattern>
              </defs>
              <circle cx="20" cy="20" r="18" fill="var({{fillVar}})"></circle>
              <circle cx="20" cy="20" r="18" fill="url(#nsw-pattern-select-{{key}})"></circle>
            </svg>
            <span class="sr-only">{{name}} patterned swatch</span>
          </td>
          <td>{{lineName}} (<code>{{lineHex}}</code>)</td>
          <td><code>{{patternContrast}}</code></td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
<p class="nsw-docs__pattern-swatch-note">{{{model.brand.nswPalette.note}}}</p>

<h4>{{model.brand.aboriginalPalette.heading}}</h4>
<div class="nsw-section nsw-section--white nsw-block nsw-p-x-sm nsw-p-top-sm">
  <div class="nsw-table nsw-table--valign-middle nsw-docs__table-wrap">
    <table class="nsw-docs__chart-colour-table">
      <caption class="sr-only">{{model.brand.aboriginalPalette.caption}}</caption>
      <colgroup>
        <col class="nsw-docs__chart-colour-col-swatch">
        <col class="nsw-docs__chart-colour-col-colour-value">
        <col class="nsw-docs__chart-colour-col-contrast">
        <col class="nsw-docs__chart-colour-col-swatch">
        <col class="nsw-docs__chart-colour-col-line-value">
        <col class="nsw-docs__chart-colour-col-pattern-contrast">
      </colgroup>
      <thead>
        <tr>
          {{#each model.brand.aboriginalPalette.headers}}
          <th>{{this}}</th>
          {{/each}}
        </tr>
      </thead>
      <tbody>
        {{#each model.brand.aboriginalPalette.rows}}
        <tr>
          <td>
            <svg class="nsw-docs__pattern-table-swatch" viewBox="0 0 40 40" aria-hidden="true" focusable="false">
              <circle cx="20" cy="20" r="18" fill="var({{fillVar}})"></circle>
            </svg>
            <span class="sr-only">{{name}} plain swatch</span>
          </td>
          <td>{{name}} (<code>{{hex}}</code>)</td>
          <td><code>{{contrast}}</code></td>
          <td>
            <svg class="nsw-docs__pattern-table-swatch" viewBox="0 0 40 40" aria-hidden="true" focusable="false">
              <defs>
                <pattern id="nsw-pattern-select-aboriginal-{{key}}" patternUnits="userSpaceOnUse" width="8" height="8">
                  <path d="M-1,1 l4,-4 M0,8 l8,-8 M6,10 l4,-4" stroke="var({{lineVar}})" stroke-width="1.5" fill="none" shape-rendering="crispEdges"></path>
                </pattern>
              </defs>
              <circle cx="20" cy="20" r="18" fill="var({{fillVar}})"></circle>
              <circle cx="20" cy="20" r="18" fill="url(#nsw-pattern-select-aboriginal-{{key}})"></circle>
            </svg>
            <span class="sr-only">{{name}} patterned swatch</span>
          </td>
          <td>{{lineName}} (<code>{{lineHex}}</code>)</td>
          <td><code>{{patternContrast}}</code></td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
<p class="nsw-docs__pattern-swatch-note">{{{model.brand.aboriginalPalette.note}}}</p>

<h3>{{model.brand.colourBlindSafety.heading}}</h3>
<p>{{model.brand.colourBlindSafety.intro}}</p>
<ul>
  {{#each model.brand.colourBlindSafety.pairs}}
  <li>{{this}}</li>
  {{/each}}
</ul>

<h3>{{model.brand.lineSeries.heading}}</h3>
<p>{{model.brand.lineSeries.intro}}</p>
<div class="nsw-section nsw-section--white nsw-block nsw-p-x-sm nsw-p-top-sm nsw-m-bottom-md nsw-docs__line-style-table-wrap">
  <div class="nsw-table nsw-table--valign-middle nsw-docs__table-wrap">
    <table>
      <caption class="sr-only">{{model.brand.lineSeries.caption}}</caption>
      <thead>
        <tr>
          <th width="30%">{{model.brand.lineSeries.headers.[0]}}</th>
          <th width="30%">{{model.brand.lineSeries.headers.[1]}}</th>
          <th width="40%">{{model.brand.lineSeries.headers.[2]}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each model.brand.lineSeries.rows}}
        <tr>
          <td><span class="nsw-docs__line-style-swatch nsw-docs__line-style-swatch--{{styleClass}}" aria-hidden="true"></span><span class="sr-only">{{srLabel}}</span></td>
          <td>{{name}}</td>
          <td>{{use}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<h3>{{model.brand.patterns.heading}}</h3>
<p>{{model.brand.patterns.intro}}</p>
<ul>
  {{#each model.brand.patterns.bullets}}
  <li>{{{this}}}</li>
  {{/each}}
</ul>
<div class="nsw-in-page-alert nsw-in-page-alert--warning nsw-m-bottom-md">
  <span class="material-icons nsw-material-icons nsw-in-page-alert__icon" focusable="false" aria-hidden="true">warning</span>
  <div class="nsw-in-page-alert__content">
    <p class="nsw-h5">{{model.brand.patterns.alert.title}}</p>
    <p>{{model.brand.patterns.alert.copy}}</p>
  </div>
</div>

<h4>{{model.brand.patterns.swatchesHeading}}</h4>
<div class="nsw-section nsw-section--white nsw-block nsw-p-x-sm nsw-p-top-sm">
  <div class="nsw-table nsw-table--valign-middle nsw-docs__table-wrap">
    <table>
      <caption class="sr-only">{{model.brand.patterns.swatchesCaption}}</caption>
      <colgroup>
        <col class="nsw-docs__pattern-usage-col-swatch">
        <col>
        <col>
      </colgroup>
      <thead>
        <tr>
          {{#each model.brand.patterns.swatchesHeaders}}
          <th>{{this}}</th>
          {{/each}}
        </tr>
      </thead>
      <tbody>
        {{#each model.brand.patterns.swatches}}
        <tr>
          <td>
            <svg class="nsw-docs__pattern-table-swatch" viewBox="0 0 40 40" aria-hidden="true" focusable="false">
              <defs>
                {{#eq patternKind "diagonal"}}
                <pattern id="nsw-pattern-usage-{{key}}" patternUnits="userSpaceOnUse" width="8" height="8">
                  <path d="M-1,1 l4,-4 M0,8 l8,-8 M6,10 l4,-4" stroke="var({{strokeVar}})" stroke-width="1.5" fill="none" shape-rendering="crispEdges"></path>
                </pattern>
                {{/eq}}
                {{#eq patternKind "crosshatch"}}
                <pattern id="nsw-pattern-usage-{{key}}" patternUnits="userSpaceOnUse" width="12" height="12">
                  <path d="M0,0 l12,12 M12,0 l-12,12" stroke="var({{strokeVar}})" stroke-width="1.5" fill="none" shape-rendering="crispEdges"></path>
                </pattern>
                {{/eq}}
                {{#eq patternKind "dots"}}
                <pattern id="nsw-pattern-usage-{{key}}" patternUnits="userSpaceOnUse" width="12" height="12">
                  <circle cx="6" cy="6" r="1.4" fill="var({{strokeVar}})"></circle>
                </pattern>
                {{/eq}}
                {{#eq patternKind "grid-tight"}}
                <pattern id="nsw-pattern-usage-{{key}}" patternUnits="userSpaceOnUse" width="8" height="8">
                  <path d="M4,0 l0,8 M0,4 l8,0" stroke="var({{strokeVar}})" stroke-width="1.5" fill="none" shape-rendering="crispEdges"></path>
                </pattern>
                {{/eq}}
                {{#eq patternKind "grid-wide"}}
                <pattern id="nsw-pattern-usage-{{key}}" patternUnits="userSpaceOnUse" width="12" height="12">
                  <path d="M6,0 l0,12 M0,6 l12,0" stroke="var({{strokeVar}})" stroke-width="1.5" fill="none" shape-rendering="crispEdges"></path>
                </pattern>
                {{/eq}}
                {{#eq patternKind "zigzag"}}
                <pattern id="nsw-pattern-usage-{{key}}" patternUnits="userSpaceOnUse" width="8" height="8">
                  <polyline points="0,0 4,4 0,8" stroke="var({{strokeVar}})" stroke-width="1.5" fill="none" shape-rendering="crispEdges"></polyline>
                  <path d="M7,-1 l2,2 M7,9 l2,-2" stroke="var({{strokeVar}})" stroke-width="1.5" fill="none" shape-rendering="crispEdges"></path>
                </pattern>
                {{/eq}}
              </defs>
              <circle cx="20" cy="20" r="18" fill="var({{fillVar}})"></circle>
              <circle cx="20" cy="20" r="18" fill="url(#nsw-pattern-usage-{{key}})"></circle>
            </svg>
          </td>
          <td>{{type}}</td>
          <td>{{use}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
<p class="nsw-docs__pattern-swatch-note">{{model.brand.patterns.swatchesNote}}</p>

<h3>{{model.brand.typography.heading}}</h3>
<p>{{model.brand.typography.intro}}</p>

<h4>{{model.brand.typography.minimumTextSizesHeading}}</h4>
<div class="nsw-grid">
  <div class="nsw-col nsw-col-sm-12 nsw-col-md-8 nsw-col-lg-8">
    <div class="nsw-section nsw-section--white nsw-block nsw-p-x-sm nsw-p-top-sm">
      <div class="nsw-table nsw-table--valign-middle nsw-docs__table-wrap">
        <table>
          <caption class="sr-only">{{model.brand.typography.minimumTextSizesCaption}}</caption>
          <thead>
            <tr>
              <th>Element</th>
              <th>Size</th>
            </tr>
          </thead>
          <tbody>
            {{#each model.brand.typography.minimumTextSizesRows}}
            <tr>
              <td>{{element}}</td>
              <td>{{size}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<p>{{model.brand.typography.minimumTextSizesNote}}</p>

<h4>{{model.brand.typography.textAlignmentHeading}}</h4>
<ul>
  {{#each model.brand.typography.textAlignment}}
  <li>{{this}}</li>
  {{/each}}
</ul>

<h4>{{model.brand.typography.numberFormattingHeading}}</h4>
<ul>
  {{#each model.brand.typography.numberFormatting}}
  <li>{{{this}}}</li>
  {{/each}}
</ul>


<h2 id="configure-tools-with-good-defaults">{{model.sections.section6.heading}}</h2>
<p>{{model.sections.section6.intro}}</p>
<ul>
  {{#each model.sections.section6.bullets}}
  <li>{{this}}</li>
  {{/each}}
</ul>


<h2 id="examples">{{model.pitfalls.heading}}</h2>
<p>{{model.pitfalls.intro}}</p>
{{#each model.pitfalls.examples}}
<h3>{{title}}</h3>
<div class="nsw-grid nsw-m-top-sm">
  {{#each panels}}
  <div class="nsw-col nsw-col-sm-6 nsw-docs__guideline">
    <div class="nsw-docs__guideline--{{variant}}">
      <span class="material-icons nsw-material-icons" focusable="false" aria-hidden="true">
        {{#eq variant "dont"}}cancel{{else}}check_circle{{/eq}}
      </span>
      <span>{{label}}</span>
    </div>
    <p>{{description}}</p>
    <div class="nsw-m-top-sm{{#eq variant "dont"}} nsw-bg--white nsw-p-sm{{/eq}}">
      <canvas id="{{canvasId}}" data-chart-height="{{canvasHeight}}" role="img" aria-label="{{ariaLabel}}"></canvas>
    </div>
    {{#if summary}}
    <p class="nsw-m-top-sm"><strong>Summary:</strong> {{summary}}</p>
    {{/if}}
    {{#if table}}
    <div class="nsw-table nsw-table--valign-middle nsw-docs__table-wrap nsw-m-top-sm">
      <table>
        <caption class="sr-only">{{table.caption}}</caption>
        <thead>
          <tr>
            {{#each table.headers}}
            <th scope="col">{{this}}</th>
            {{/each}}
          </tr>
        </thead>
        <tbody>
          {{#each table.rows}}
          <tr>
            <th scope="row">{{label}}</th>
            {{#each values}}
            <td>{{this}}</td>
            {{/each}}
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}
    <ul>
      {{#each bullets}}
      <li>{{this}}</li>
      {{/each}}
    </ul>
  </div>
  {{/each}}
</div>
{{/each}}


<h2 id="review-checklist">{{model.review.checklistHeading}}</h2>
<div class="nsw-docs__review-checklist nsw-m-top-sm nsw-p-md nsw-bg--brand-dark nsw-section--invert">
  <div class="nsw-docs__review-checklist-header nsw-section--invert">
    <p class="nsw-m-bottom-xs"><strong>{{model.review.checklistLead}}</strong></p>
  </div>
  <fieldset id="chart-review-checklist" class="nsw-form__fieldset" aria-describedby="review-checklist-help">
    <legend class="sr-only">{{model.review.checklistLegend}}</legend>
    {{#each model.review.checklistItems}}
    <input class="nsw-form__checkbox-input" type="checkbox" id="chart-review-check-{{id}}">
    <label class="nsw-form__checkbox-label" for="chart-review-check-{{id}}">{{text}}</label>
    {{/each}}
  </fieldset>
</div>
<p id="review-checklist-help" class="nsw-docs__review-checklist-help">{{model.review.checklistHelp}}</p>

<h2 id="full-docs">{{model.review.referencesHeading}}</h2>
<ul>
  {{#each model.review.references}}
  <li>{{{this}}}</li>
  {{/each}}
</ul>

<script src="/docs/js/charts-and-graphs.js"></script>
