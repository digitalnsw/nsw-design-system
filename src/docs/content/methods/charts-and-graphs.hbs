<h3>Proportion</h3>
<h4 id="chart-doughnut" class="nsw-m-bottom-sm">Doughnut</h4>
<div class="nsw-grid nsw-m-top-md">
  <div class="nsw-col nsw-col-md-5 nsw-col-lg-5">
    <canvas id="chartPropDoughnut" height="200" role="img" aria-label="Doughnut chart example showing approval status."></canvas>
    {{#> _docs-code code="js"}}
const ctx = document.getElementById('chartPropDoughnut');
const { createPattern, defaultPatternSources } = window.NSWChartUtilities;
const styles = getComputedStyle(document.body);
const blue02 = styles.getPropertyValue('--nsw-palette-blue-02').trim();
const yellow02 = styles.getPropertyValue('--nsw-palette-yellow-02').trim();
const red02 = styles.getPropertyValue('--nsw-palette-red-02').trim();

new Chart(ctx, {
  type: 'doughnut',
  data: {
    labels: ['Approved', 'Pending', 'Declined'],
    datasets: [{
      data: [62, 24, 14],
      backgroundColor: (context) => {
        if (context.dataIndex === 1) {
          return createPattern(context, {
            style: 'diagonal',
            baseColor: '--nsw-palette-yellow-02',
            patternSources: defaultPatternSources,
            size: 8
          });
        }
        return [blue02, yellow02, red02][context.dataIndex];
      }
    }]
  },
  options: { plugins: { legend: { position: 'bottom' } } }
});
    {{/_docs-code}}
  </div>
  <div class="nsw-col nsw-col-md-7 nsw-col-lg-7">
    <ul class="nsw-list nsw-list--8 nsw-docs__list-stack">
      <li><strong>Use when:</strong> Showing simple proportion (2 to 4 segments).</li>
      <li><strong>Avoid when:</strong> Many small slices.</li>
      <li><strong>Notes:</strong> Include percentage and total value.</li>
    </ul>
  </div>
</div>
