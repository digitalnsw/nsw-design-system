    <label class="nsw-form__checkbox-label" for="chart-review-check-4">Colour is supported by labels, markers or patterns.</label>
    <input class="nsw-form__checkbox-input" type="checkbox" id="chart-review-check-5">
    <label class="nsw-form__checkbox-label" for="chart-review-check-5">A semantic data table is provided.</label>
    <input class="nsw-form__checkbox-input" type="checkbox" id="chart-review-check-6">
    <label class="nsw-form__checkbox-label" for="chart-review-check-6">Keyboard access is supported where interaction exists.</label>
    <input class="nsw-form__checkbox-input" type="checkbox" id="chart-review-check-7">
    <label class="nsw-form__checkbox-label" for="chart-review-check-7">The chart remains usable at 200 percent zoom.</label>
    <input class="nsw-form__checkbox-input" type="checkbox" id="chart-review-check-8">
    <label class="nsw-form__checkbox-label" for="chart-review-check-8">Units and data source are clearly stated.</label>
  </fieldset>
</div>
<p id="review-checklist-help" class="nsw-docs__review-checklist-help">If any answer is no, revise before release.</p>

