        <tr>
          <td><span class="nsw-docs__line-style-swatch nsw-docs__line-style-swatch--solid" aria-hidden="true"></span><span class="sr-only">Solid line style</span></td>
          <td>Solid</td>
          <td>Primary series</td>
        </tr>
        <tr>
          <td><span class="nsw-docs__line-style-swatch nsw-docs__line-style-swatch--dashed" aria-hidden="true"></span><span class="sr-only">Dashed line style</span></td>
          <td>Dashed</td>
          <td>Secondary</td>
        </tr>
        <tr>
          <td><span class="nsw-docs__line-style-swatch nsw-docs__line-style-swatch--dotted" aria-hidden="true"></span><span class="sr-only">Dotted line style</span></td>
