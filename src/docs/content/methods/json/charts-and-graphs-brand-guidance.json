  },
  "patterns": {
    "heading": "Using patterns",
    "intro": "Colour is usually the primary cue for distinguishing datasets, but charts must remain understandable when users cannot rely on colour alone.",
    "bullets": [
      "Use two colours per pattern: a fill and a pattern stroke.",
      "Keep at least <code>3:1</code> contrast between fill and pattern stroke.",
      "Use colours from the same palette column where possible (for example, Blue 03 fill with Blue 01 pattern).",
      "Use patterns sparingly to avoid visual noise; keep to 4 to 5 patterns maximum in one chart.",
      "Avoid thin lines or dense patterns; use stroke widths between 1.5 and 2px.",
      "Avoid complicated image-based patterns."
    ],
    "alert": {
      "title": "Pattern usage limits",
      "copy": "Keep to 4 to 5 patterns maximum in a single chart. Avoid thin lines or dense fills, use stroke widths 1.5 to 2px. Validate at 200% zoom and 375px viewport width before publishing. Patterns are reference swatches only: final scale must be validated in the rendered environment."
    },
    "swatchesHeading": "Pattern swatch examples",
    "swatchesCaption": "Pattern swatch examples and typical use cases",
    "swatchesHeaders": [
      "Swatch",
      "Pattern type",
      "Typical use"
    ],
