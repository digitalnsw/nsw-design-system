  "colourBlindSafety": {
    "heading": "Colour-blind safety",
    "intro": "The most common type of colour vision deficiency is red-green confusion. Avoid placing these colour pairs next to each other:",
    "pairs": [
      "Green and brown",
      "Red and brown",
      "Purple and blue"
    ]
  },
  "lineSeries": {
    "heading": "Line-series differentiation",
    "intro": "For line charts, use dash styles, not fill patterns. Dash patterns (solid, dashed, dotted, dash-dot) are the correct redundant channel for distinguishing line series. Fill patterns are for bar, area and pie/doughnut chart marks only.",
    "caption": "Line style definitions for chart series differentiation",
    "headers": [
      "Style swatch",
      "Name",
      "Use"
    ],
    "rows": [
