{
  "heading": "5. Apply NSW brand consistently",
  "intro": "Apply NSW brand colour and typography with care. Prioritise contrast and readability, and do not use the palette decoratively.",
  "selectionMethod": {
    "heading": "Recommended colour selection method",
    "contrastRule": "For accessibility compliance, data marks must have a minimum contrast ratio of <code>3:1</code> against the background surface.",
    "intro": "We recommend the following method for selecting your colours:",
    "beforeImageText": "Start with 01 and 02 colours from your main colour theme. If your colour theme is Blue and Red, use Blue 01, Blue 02, Red 01, Red 02.",
    "afterImageText": "Once that colour is exhausted, you can use colours from additional colour columns starting from 01 and then 02 colours.",
    "consistencyText": "If you have a series of charts, use the same colours for the same categories across all your charts. This makes it easier for users to follow the story and they will be less likely to mistake one data series for another.",
    "images": [
      {
        "src": "/assets/images/charts-and-graphs-colour-selection-1.png",
        "alt": "Colour selection example showing use of 01 and 02 colours from the main theme before introducing additional palette columns."
      },
      {
        "src": "/assets/images/charts-and-graphs-colour-selection-2.png",
        "alt": "Chart series example demonstrating consistent category colours across multiple charts for easier comparison."
      }
    ],
    "warning": "<strong>Excluded:</strong> Yellow 02 (<code>#FAAF05</code>) is <code>1.88:1</code> on white and is not compliant for chart marks."
  },
  "background": {
    "heading": "Background colour",
    "text": "Charts must use a white background (<code>#FFFFFF</code> or <code>--nsw-brand-white</code>) to ensure sufficient contrast for data marks."
  },
