{
  "checklistHeading": "Review checklist",
  "checklistLead": "Before publishing:",
  "checklistLegend": "Charts and graphs review checklist",
  "checklistItems": [
    {
      "id": "1",
      "text": "Does the chart match the user task?"
    },
    {
      "id": "2",
      "text": "Is it the simplest suitable type?"
    },
    {
      "id": "3",
      "text": "Is contrast sufficient?"
    },
    {
      "id": "4",
      "text": "Is colour supported by other markers?"
    },
    {
      "id": "5",
      "text": "Is there a semantic table?"
    },
    {
      "id": "6",
      "text": "Is keyboard access supported?"
    },
    {
      "id": "7",
      "text": "Does it work at 200% zoom?"
    },
    {
      "id": "8",
      "text": "Are units and source clearly stated?"
    }
  ],
  "checklistHelp": "If any answer is no, revise before release.",
  "referencesHeading": "References",
  "references": [
